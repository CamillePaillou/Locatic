apiVersion: apps/v1
kind: Deployment
metadata:
  name: locatic-app
  labels:
    app: locatic
spec:
  replicas: {{ app_replicas }}
  selector:
    matchLabels:
      app: locatic
  template:
    metadata:
      labels:
        app: locatic
      annotations:
        # Branché à l'étape 17 : l'app n'expose pas encore /metrics.
        prometheus.io/scrape: "true"
        prometheus.io/port: "{{ metrics_port }}"
        prometheus.io/path: "{{ metrics_path }}"
    spec:
      imagePullSecrets:
        - name: ghcr-pull-secret
      containers:
        - name: locatic
          image: "{{ app_image_repository }}:{{ app_image_tag }}"
          ports:
            - name: http
              containerPort: 8080
          env:
{% for key, value in app_env.items() %}
            - name: "{{ key }}"
              value: "{{ value }}"
{% endfor %}
            - name: ConnectionStrings__Default
              value: "Data Source={{ sqlite_mount_path }}/locatic.db"
          volumeMounts:
            - name: sqlite-storage
              mountPath: "{{ sqlite_mount_path }}"
          resources:
            requests:
              cpu: "{{ app_resources.requests.cpu }}"
              memory: "{{ app_resources.requests.memory }}"
            limits:
              cpu: "{{ app_resources.limits.cpu }}"
              memory: "{{ app_resources.limits.memory }}"
          readinessProbe:
            httpGet:
              path: /health/ready
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health/live
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
      volumes:
        - name: sqlite-storage
          persistentVolumeClaim:
            claimName: "{{ locatic_sqlite_pvc }}"
