apiVersion: v1
kind: Secret
metadata:
  name: ghcr-pull-secret
type: kubernetes.io/dockerconfigjson
data:
  # Secret minimal : uniquement l'entrée ghcr.io, construite à partir de
  # GHCR_USERNAME / GHCR_TOKEN passés en variables d'environnement au
  # playbook (jamais committés, jamais stockés dans un fichier).
  .dockerconfigjson: >-
    {{
      {
        "auths": {
          ghcr_registry: {
            "username": ghcr_username,
            "password": ghcr_token,
            "auth": (ghcr_username ~ ':' ~ ghcr_token) | b64encode
          }
        }
      } | to_json | b64encode
    }}
