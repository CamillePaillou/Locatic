apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-config
data:
  default.conf: |
    server {
        listen 80;
        server_name _;

        location / {
            proxy_pass http://locatic-app-svc.{{ locatic_namespace }}.svc.cluster.local;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # Statistiques internes Nginx (connexions actives, requêtes traitées).
        # Restreint à localhost : seul le sidecar nginx-exporter du même pod
        # y accède, jamais exposé au reverse proxy public.
        location /nginx_status {
            stub_status;
            allow 127.0.0.1;
            deny all;
        }
    }
