@model List<CarBrand>
@{
    ViewData["Title"] = "Marques";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Marques</h1>
    <a asp-action="Create" class="btn btn-primary">Ajouter une marque</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Pays d'origine</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var brand in Model)
        {
            <tr>
                <td>@brand.Name</td>
                <td>@(brand.CountryOfOrigin ?? "—")</td>
            </tr>
        }
    </tbody>
</table>
