@model Booking
@{
    ViewData["Title"] = "Détail réservation";
    var nbDays = Model.EndDate.DayNumber - Model.StartDate.DayNumber;
    var total = nbDays * Model.Car.DayRate;
}

<h1>Réservation — @Model.Client.FirstName @Model.Client.LastName</h1>

<dl class="row mt-3">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client.FirstName @Model.Client.LastName</dd>

    <dt class="col-sm-3">Voiture</dt>
    <dd class="col-sm-9">@Model.Car.Model.Brand.Name @Model.Car.Model.Name — @Model.Car.Registration</dd>

    <dt class="col-sm-3">Date de début</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

    <dt class="col-sm-3">Date de fin</dt>
    <dd class="col-sm-9">@Model.EndDate.ToString("dd/MM/yyyy")</dd>

    <dt class="col-sm-3">Durée</dt>
    <dd class="col-sm-9">@nbDays jour(s)</dd>

    <dt class="col-sm-3">Tarif journalier</dt>
    <dd class="col-sm-9">@Model.Car.DayRate €</dd>

    <dt class="col-sm-3">Total</dt>
    <dd class="col-sm-9"><strong>@total €</strong></dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifier</a>
<a asp-action="Index" class="btn btn-secondary ms-2">Retour</a>
