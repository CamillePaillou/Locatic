@model Booking
@{
    ViewData["Title"] = "Supprimer une réservation";
}

<h1>Supprimer une réservation</h1>
<p class="text-danger">Êtes-vous sûr de vouloir supprimer cette réservation ?</p>

<dl class="row mt-3">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client.FirstName @Model.Client.LastName</dd>

    <dt class="col-sm-3">Voiture</dt>
    <dd class="col-sm-9">@Model.Car.Model.Brand.Name @Model.Car.Model.Name — @Model.Car.Registration</dd>

    <dt class="col-sm-3">Période</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("dd/MM/yyyy") → @Model.EndDate.ToString("dd/MM/yyyy")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Annuler</a>
</form>
