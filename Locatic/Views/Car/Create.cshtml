@model CarCreateVM
@using Locatic.Enums
@{
    ViewData["Title"] = "Ajouter une voiture";
}

<h1>Ajouter une voiture</h1>

<form asp-action="Create" method="post" class="mt-3" style="max-width: 500px">
    <div class="mb-3">
        <label asp-for="Registration" class="form-label">Immatriculation</label>
        <input asp-for="Registration" class="form-control" />
        <span asp-validation-for="Registration" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Year" class="form-label">Année</label>
        <input asp-for="Year" class="form-control" />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DayRate" class="form-label">Tarif journalier (€)</label>
        <input asp-for="DayRate" class="form-control" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="DayRate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="NbSeats" class="form-label">Nombre de places</label>
        <input asp-for="NbSeats" class="form-control" />
        <span asp-validation-for="NbSeats" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Fuel" class="form-label">Carburant</label>
        <select asp-for="Fuel" class="form-select"
                asp-items="@Html.GetEnumSelectList<Fuel>()">
            <option value="">-- Choisir --</option>
        </select>
        <span asp-validation-for="Fuel" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CarModelId" class="form-label">Modèle</label>
        <select asp-for="CarModelId" class="form-select"
                asp-items="@(new SelectList(Model.Models, "Id", "Name"))">
            <option value="">-- Choisir un modèle --</option>
        </select>
        <span asp-validation-for="CarModelId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Annuler</a>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
