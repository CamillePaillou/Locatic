@model Car
@{
    ViewData["Title"] = "Détail voiture";
}

<h1>@Model.Model.Brand.Name @Model.Model.Name</h1>

<dl class="row mt-3">
    <dt class="col-sm-3">Immatriculation</dt>
    <dd class="col-sm-9">@Model.Registration</dd>

    <dt class="col-sm-3">Marque</dt>
    <dd class="col-sm-9">@Model.Model.Brand.Name</dd>

    <dt class="col-sm-3">Modèle</dt>
    <dd class="col-sm-9">@Model.Model.Name</dd>

    <dt class="col-sm-3">Année</dt>
    <dd class="col-sm-9">@Model.Year</dd>

    <dt class="col-sm-3">Tarif journalier</dt>
    <dd class="col-sm-9">@Model.DayRate €</dd>

    <dt class="col-sm-3">Places</dt>
    <dd class="col-sm-9">@Model.NbSeats</dd>

    <dt class="col-sm-3">Carburant</dt>
    <dd class="col-sm-9">@Model.Fuel</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifier</a>
<a asp-action="Index" class="btn btn-secondary ms-2">Retour</a>
