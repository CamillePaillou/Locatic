@model List<CarModel>
@{
    ViewData["Title"] = "Modèles";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Modèles</h1>
    <a asp-action="Create" class="btn btn-primary">Ajouter un modèle</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Marque</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var carModel in Model)
        {
            <tr>
                <td>@carModel.Name</td>
                <td>@carModel.Brand.Name</td>
            </tr>
        }
    </tbody>
</table>
