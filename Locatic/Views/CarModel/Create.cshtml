@model CarModelCreateVM
@{
    ViewData["Title"] = "Ajouter un modèle";
}

<h1>Ajouter un modèle</h1>

<form asp-action="Create" method="post" class="mt-3" style="max-width: 500px">
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Nom</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CarBrandId" class="form-label">Marque</label>
        <select asp-for="CarBrandId" class="form-select"
                asp-items="@(new SelectList(Model.Brands, "Id", "Name"))">
            <option value="">-- Choisir une marque --</option>
        </select>
        <span asp-validation-for="CarBrandId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Annuler</a>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
