@model CarBrandCreateVM
@{
    ViewData["Title"] = "Ajouter une marque";
}

<h1>Ajouter une marque</h1>

<form asp-action="Create" method="post" class="mt-3" style="max-width: 500px">
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Nom</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CountryOfOrigin" class="form-label">Pays d'origine (optionnel)</label>
        <input asp-for="CountryOfOrigin" class="form-control" />
        <span asp-validation-for="CountryOfOrigin" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Annuler</a>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
