@model Client
@{
    ViewData["Title"] = "Supprimer un client";
}

<h1>Supprimer un client</h1>
<p class="text-danger">Êtes-vous sûr de vouloir supprimer ce client ?</p>

<dl class="row mt-3">
    <dt class="col-sm-3">Nom</dt>
    <dd class="col-sm-9">@Model.LastName</dd>

    <dt class="col-sm-3">Prénom</dt>
    <dd class="col-sm-9">@Model.FirstName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Annuler</a>
</form>
