@model Client
@{
    ViewData["Title"] = "Détail client";
}

<h1>@Model.FirstName @Model.LastName</h1>

<dl class="row mt-3">
    <dt class="col-sm-3">Nom</dt>
    <dd class="col-sm-9">@Model.LastName</dd>

    <dt class="col-sm-3">Prénom</dt>
    <dd class="col-sm-9">@Model.FirstName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Téléphone</dt>
    <dd class="col-sm-9">@(Model.PhoneNumber ?? "—")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifier</a>
<a asp-action="Index" class="btn btn-secondary ms-2">Retour</a>
